{
  "name": "dommy-on-desk",
  "version": "0.8.0",
  "description": "A desktop pet that lives on your screen.",
  "main": "src/main.js",
  "scripts": {
    "start": "node scripts/ensure-sidecar-binaries.js && node launch.js",
    "build": "electron-builder --win",
    "build:win:x64": "electron-builder --win nsis:x64",
    "build:win:arm64": "electron-builder --win nsis:arm64",
    "build:win:all": "electron-builder --win nsis:x64 nsis:arm64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --mac --linux",
    "fetch:sidecars": "node scripts/fetch-sidecar-binaries.js",
    "verify:sidecars": "node scripts/verify-sidecar-binaries.js",
    "prebuild": "node scripts/verify-sidecar-binaries.js",
    "prebuild:win:x64": "node scripts/verify-sidecar-binaries.js",
    "prebuild:win:arm64": "node scripts/verify-sidecar-binaries.js",
    "prebuild:win:all": "node scripts/verify-sidecar-binaries.js",
    "prebuild:mac": "node scripts/verify-sidecar-binaries.js",
    "prebuild:linux": "node scripts/verify-sidecar-binaries.js",
    "prebuild:all": "node scripts/verify-sidecar-binaries.js",
    "test": "node test/run-tests.js",
    "create-theme": "node scripts/create-theme.js"
  },
  "keywords": [
    "desktop-pet",
    "electron",
    "pomeranian"
  ],
  "author": "rullerzhou-afk",
  "license": "AGPL-3.0-only",
  "type": "commonjs",
  "build": {
    "appId": "com.dommy.on-desk",
    "productName": "Dommy on Desk",
    "mac": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.entertainment",
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "win": {
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false,
      "artifactName": "Dommy-on-Desk-Setup-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "maintainer": "rullerzhou-afk <rullerzhou-afk@users.noreply.github.com>",
      "icon": "assets/icons",
      "category": "Utility",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "buildUniversalInstaller": false,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "include": "build/installer.nsh"
    },
    "files": [
      "NOTICE.md",
      "src/**/*",
      "assets/icon.ico",
      "assets/icons/**/*",
      "assets/svg/**/*",
      "assets/sounds/**/*",
      "assets/tray-icon*.png",
      "themes/**/*"
    ],
    "asarUnpack": [
      "assets/svg/**/*",
      "themes/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/icon.ico",
        "to": "icon.ico"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "rullerzhou-afk",
        "repo": "dommy-on-desk"
      }
    ]
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "htmlparser2": "^12.0.0",
    "koffi": "^2.15.2"
  }
}
