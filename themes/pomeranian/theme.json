{
  "schemaVersion": 1,
  "name": "Pomeranian",
  "author": "rullerzhou",
  "version": "1.0.0",
  "description": "A fluffy Pomeranian desk pet — walks, lies down, and wags its tail when you hover",
  "viewBox": { "x": 0, "y": 0, "width": 640, "height": 1136 },
  "eyeTracking": {
    "enabled": false,
    "states": []
  },
  "states": {
    "idle": ["front.png"],
    "working": ["front.png"],
    "thinking": ["front.png"],
    "happy": ["happy.gif"],
    "sleeping": { "files": ["front.png"], "fallbackTo": "idle" },
    "dozing": { "files": ["front.png"], "fallbackTo": "idle" },
    "collapsing": { "files": ["front.png"], "fallbackTo": "idle" },
    "yawning": { "files": ["front.png"], "fallbackTo": "idle" },
    "waking": { "files": ["front.png"], "fallbackTo": "idle" },
    "attention": { "files": ["happy.gif"], "fallbackTo": "happy" },
    "notification": { "files": ["happy.gif"], "fallbackTo": "happy" },
    "error": { "files": ["front.png"], "fallbackTo": "idle" },
    "sweeping": { "files": ["walking.gif"], "fallbackTo": "working" },
    "carrying": { "files": ["walking.gif"], "fallbackTo": "working" },
    "juggling": { "files": ["walking.gif"], "fallbackTo": "working" }
  },
  "sleepSequence": { "mode": "direct" },
  "miniMode": { "supported": false },
  "dockWalk": { "supported": true },
  "objectScale": {
    "widthRatio": 1.9,
    "heightRatio": 1.3,
    "offsetX": -0.45,
    "offsetY": -0.25,
    "fileScales": {
      "front.png": 0.75,
      "walking.gif": 0.85,
      "happy.gif": 0.70,
      "side.png": 0.9
    }
  },
  "timings": {
    "minDisplay": {
      "attention": 4000,
      "error": 5000,
      "sweeping": 5500,
      "notification": 2500,
      "carrying": 3000,
      "working": 1000,
      "thinking": 1000,
      "happy": 500
    },
    "autoReturn": {
      "attention": 4000,
      "error": 5000,
      "sweeping": 300000,
      "notification": 2500,
      "carrying": 3000
    },
    "deepSleepTimeout": 600000,
    "mouseIdleTimeout": 20000,
    "mouseSleepTimeout": 60000
  },
  "hitBoxes": {
    "default": { "x": 80, "y": 30, "w": 480, "h": 1070 },
    "sleeping": { "x": 80, "y": 200, "w": 480, "h": 900 },
    "wide": { "x": 40, "y": 20, "w": 560, "h": 1100 }
  },
  "wideHitboxFiles": [
    "happy.gif",
    "walking.gif"
  ],
  "sleepingHitboxFiles": [
    "front.png"
  ]
}
